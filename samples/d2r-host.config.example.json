{
  "mode": "master",
  "nodeId": "server-a",
  "nodeHeartbeatSeconds": 15,
  "agentOfflineAfterSeconds": 45,
  "discordToken": "replace_with_discord_bot_token_or_use_DISCORD_TOKEN_env",
  "discordGuildId": null,
  "disableDiscord": false,
  "httpPort": 8080,
  "windowsFirewall": {
    "manage": true,
    "trustedNetworks": [
      "LocalSubnet"
    ],
    "reconcileSeconds": 30
  },
  "databasePath": "C:\\D2ROps\\d2r-host.sqlite",
  "allowedDiscordUserIds": [
    "your_discord_user_id"
  ],
  "startAllDelaySeconds": 20,
  "gameSessionNotificationsEnabled": false,
  "updateNotificationsEnabled": true,
  "guildChannel": null,
  "powerShellPath": "powershell.exe",
  "powerShellTimeoutSeconds": 90,
  "allowedVmNamePrefixes": [
    "d2r-"
  ],
  "agents": {
    "d2r-hc-01": {
      "kind": "vm",
      "displayName": "BO-01 VM Agent",
      "sharedSecret": "replace_with_long_random_vm_secret_01",
      "remoteUrl": "parsec://optional-remote-control-link"
    },
    "d2r-hc-02": {
      "kind": "vm",
      "displayName": "BO-02 VM Agent",
      "sharedSecret": "replace_with_long_random_vm_secret_02"
    },
    "server-b": {
      "kind": "host",
      "displayName": "Second Hyper-V Host",
      "sharedSecret": "replace_with_long_random_node_secret_02"
    }
  },
  "accounts": {
    "hc1": {
      "agentId": "d2r-hc-01",
      "nodeId": "server-a",
      "vmName": "d2r-hc-01",
      "displayName": "BO-01",
      "characterSlot": 1
    },
    "hc2": {
      "agentId": "d2r-hc-02",
      "nodeId": "server-a",
      "vmName": "d2r-hc-02",
      "displayName": "BO-02",
      "characterSlot": 1
    }
  }
}
