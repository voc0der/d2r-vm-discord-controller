DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me
# Optional: guild registration is instant; global command registration can take a while.
DISCORD_GUILD_ID=

LOG_LEVEL=info
CONTROLLER_PORT=8080
CONTROLLER_IMAGE=d2r-vm-discord-controller:local
# Overrides controller.config.json startAllDelaySeconds for *-all client commands.
CLIENT_STAGGER_SECONDS=30
